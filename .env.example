# Общие
APP_ENV=development
APP_NAME=peskovp-platform
LOG_LEVEL=info

# API
API_HOST=127.0.0.1
API_PORT=8080

# WEB
WEB_HOST=127.0.0.1
WEB_PORT=3000
# Auth / session secrets (server-only)
AUTH_SECRET=REPLACE_IN_SECRET_MANAGER
NEXTAUTH_SECRET=REPLACE_IN_SECRET_MANAGER

# AI module
AI_PROVIDER=openai
AI_MODEL=gpt-5
OPENAI_API_KEY=REPLACE_IN_SECRET_MANAGER
OPENAI_BASE_URL=https://api.openai.com/v1
AI_REQUIRE_AUTH=true
AI_API_AUTH_TOKEN=REPLACE_IN_SECRET_MANAGER
AI_RATE_LIMIT_RPM=20
AI_MAX_PROMPT_CHARS=6000
AI_HISTORY_LIMIT=50
AI_USAGE_LOG_PATH=services/ai-module/logs/usage.jsonl
AI_PROMPT_DIR=services/ai-module/prompts
AI_DEFAULT_TEMPLATE=support_assistant
AI_STREAMING_ENABLED=true
# Telegram
TELEGRAM_BOT_TOKEN=REPLACE_IN_SECRET_MANAGER
TELEGRAM_WEBHOOK_SECRET=REPLACE_IN_SECRET_MANAGER
TELEGRAM_INITDATA_MAX_AGE_SECONDS=300
TELEGRAM_MINI_APP_URL=https://t.me/peskovp_bot/app

# Payments
PAYMENT_PROVIDER=manual
PAYMENTS_TELEGRAM_WEBHOOK_SECRET=REPLACE_IN_SECRET_MANAGER
PAYMENTS_YOOKASSA_WEBHOOK_SECRET=REPLACE_IN_SECRET_MANAGER
YOOKASSA_SHOP_ID=REPLACE_IN_SECRET_MANAGER
YOOKASSA_SECRET_KEY=REPLACE_IN_SECRET_MANAGER
CLOUDPAYMENTS_API_SECRET=REPLACE_IN_SECRET_MANAGER

# VPN integration (read-only)
VPN_READONLY_MODE=true
VPN_PANEL_BASE_URL=https://panel.example.com
# VPN_PANEL_TOKEN=REPLACE_IN_SECRET_MANAGER

# VPN V2 controlled rollout
VPN_V2_CANARY_PERCENT=1
VPN_V2_CANARY_SALT=REPLACE_WITH_SECURE_RANDOM
VPN_V2_REGISTRY_PATH=apps/api/src/vpn_v2_api/sample_nodes.json
VPN_V2_HIDDEN_SUBSCRIPTION_PATH=/v2/subscription/canary
VPN_V2_ENABLE_RF_GATEWAY=true
VPN_V2_TELEGRAM_MINIAPP_URL=https://t.me/peskovp_bot/app

# PHASE 15 — docker-compose.prod
APP_BIND_PORT=3100
API_BIND_PORT=18080
AI_BIND_PORT=8787
POSTGRES_USER=peskovp
POSTGRES_DB=peskovp
# POSTGRES_PASSWORD=REPLACE_IN_SECRET_MANAGER
DATABASE_URL=postgresql://peskovp:REPLACE_IN_SECRET_MANAGER@postgres:5432/peskovp
REDIS_URL=redis://redis:6379/0
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

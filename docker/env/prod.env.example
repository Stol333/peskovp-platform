APP_ENV=production

# Loopback-only publish (host nginx proxy target)
APP_BIND_PORT=3100
API_BIND_PORT=18080
AI_BIND_PORT=8787

# DB / cache (internal only)
POSTGRES_USER=peskovp
POSTGRES_DB=peskovp
POSTGRES_PASSWORD=REPLACE_IN_SECRET_MANAGER
DATABASE_URL=postgresql://peskovp:REPLACE_IN_SECRET_MANAGER@postgres:5432/peskovp
REDIS_URL=redis://redis:6379/0

# AI module
AI_PROVIDER=openai
AI_MODEL=gpt-5
OPENAI_API_KEY=REPLACE_IN_SECRET_MANAGER
OPENAI_BASE_URL=https://api.openai.com/v1
AI_REQUIRE_AUTH=true
AI_API_AUTH_TOKEN=REPLACE_IN_SECRET_MANAGER
AI_RATE_LIMIT_RPM=20
AI_MAX_PROMPT_CHARS=6000
AI_HISTORY_LIMIT=50
AI_DEFAULT_TEMPLATE=support_assistant
AI_STREAMING_ENABLED=true
AI_LOG_SUMMARY_MAX_CHARS=30000
AI_LOG_SUMMARY_MAX_LINES=20

# VPN V2 rollout
VPN_V2_CANARY_PERCENT=1
VPN_V2_CANARY_SALT=REPLACE_WITH_SECURE_RANDOM
VPN_V2_CANARY_TEST_USERS=
VPN_V2_REGISTRY_PATH=apps/api/src/vpn_v2_api/sample_nodes.json
VPN_V2_TELEGRAM_MINIAPP_URL=https://t.me/peskovp_bot/app
VPN_V2_HIDDEN_SUBSCRIPTION_PATH=/v2/subscription/canary
VPN_V2_SUBSCRIPTION_DOMAIN=sub.peskovp.com
VPN_V2_ENABLE_RF_GATEWAY=true
VPN_WRITE_ENABLED=false
VPN_PROVISIONING_DRY_RUN=true
VPN_PROVISIONING_EXPLICIT_APPROVAL=true
VPN_API_BASE_URL=https://vpn-panel.example.com
VPN_API_TOKEN=REPLACE_IN_SECRET_MANAGER
VPN_HTTP_TIMEOUT_SECONDS=10
VPN_VERIFY_TLS=true

# Log rotation
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
